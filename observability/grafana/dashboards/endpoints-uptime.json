{
  "uid": "endpoints-uptime",
  "title": "Endpoints / Uptime",
  "tags": ["observability", "blackbox", "uptime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Endpoint status",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "probe_success", "legendFormat": "{{instance}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } } ],
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ], "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" } }
    },
    {
      "id": 2, "type": "stat", "title": "TLS cert — days left",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400", "legendFormat": "{{instance}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } } ],
      "fieldConfig": { "defaults": { "unit": "d", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 14 }, { "color": "green", "value": 30 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3, "type": "timeseries", "title": "Probe duration",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "probe_duration_seconds", "legendFormat": "{{instance}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 4, "type": "timeseries", "title": "Availability (probe_success)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "probe_success", "legendFormat": "{{instance}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ],
      "fieldConfig": { "defaults": { "unit": "bool", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20 } }, "overrides": [] }
    },
    {
      "id": 5, "type": "table", "title": "Endpoints — 24h availability",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "avg_over_time(probe_success[24h]) * 100", "format": "table", "instant": true, "legendFormat": "{{instance}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true, "job": true }, "renameByName": { "instance": "Endpoint", "Value": "Availability 24h" } } } ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "custom": { "displayMode": "gradient-gauge" }, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 } ] } }, "overrides": [] }
    }
  ]
}
