# Скопировать в .env и заполнить. Реальные секреты НЕ коммитим.

# Пароль админа Grafana (логин: admin). Анонимный доступ выключен.
GRAFANA_ADMIN_PASSWORD=change_me_strong

# Бот «Фриланс сервер» — вся техничка инфраструктуры идёт сюда (Alertmanager → Telegram).
SERVER_BOT_TOKEN=000:change_me
SERVER_CHAT_ID=000

# GID группы docker на хосте (для read-only доступа экспортёра к docker.sock).
# Узнать: stat -c '%g' /var/run/docker.sock
DOCKER_GID=994
