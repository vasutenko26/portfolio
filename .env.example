# Скопировать в .env и заполнить
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=wordpress
MYSQL_USER=wp
MYSQL_PASSWORD=change_me

WORDPRESS_DB_HOST=mariadb
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wp
WORDPRESS_DB_PASSWORD=change_me

SITE_DOMAIN=example.com
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me
WP_ADMIN_EMAIL=admin@example.com

# --- n8n (автоматизация) ---
N8N_DB_PASSWORD=change_me
N8N_ENCRYPTION_KEY=change_me_32+chars
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASS=change_me
N8N_OWNER_EMAIL=admin@example.com
N8N_OWNER_PASSWORD=change_me
TELEGRAM_BOT_TOKEN=000:change_me
TELEGRAM_CHAT_ID=000
GEMINI_API_KEY=change_me
GEMINI_MODEL=gemini-2.5-flash
SITE_HEALTH_URL=https://example.com/
WP_LOGIN_SLUG=secret-admin-path
