# Скопировать в .env и заполнить. Реальные секреты НЕ коммитим.
# Значения TELEGRAM_* — те же, что у остальной инфраструктуры (общий бот алертов).

# --- Uptime Kuma ---
# Пин версии образа (репродьюсибилити). Сменить — поднять/опустить аккуратно.
KUMA_VERSION=1.23.16

# Админ статус-панели (создаётся провижном при первом запуске).
KUMA_ADMIN_USER=david
KUMA_ADMIN_PASSWORD=change_me_strong

# Публичный поддомен (должен иметь A-запись в DNS на этот сервер).
STATUS_DOMAIN=status.davidvasutenko.fun

# --- Telegram: бот «Фриланс сервер» (вся техничка инфраструктуры идёт сюда) ---
SERVER_BOT_TOKEN=000:change_me
SERVER_CHAT_ID=000

# Учения по алертам: true — провижн добавит скрытый монитор drill-мишени.
DRILL=false
