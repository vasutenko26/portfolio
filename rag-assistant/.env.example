# Скопировать в .env и заполнить. Секреты НЕ коммитим.

# --- Эмбеддинги (self-hosted, без платных API) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Чанкинг / поиск ---
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
MAX_UPLOAD_MB=25
COLLECTION=documents

# --- LLM генерации ответа: gemini | openai | ollama ---
# gemini/openai отправляют контекст наружу; ollama = полностью on-prem (данные не уходят).
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=change_me
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (или совместимый endpoint)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (локальный LLM; запустить отдельно/в своём compose и указать URL)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
